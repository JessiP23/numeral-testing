{
  "name": "compliance",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "worker": "tsx workers/transactionWorker.ts",
    "sync": "tsx -r dotenv/config scripts/sync-stripe.ts dotenv_config_path=.env.local",
    "cleanup": "tsx -r dotenv/config scripts/cleanup.ts dotenv_config_path=.env.local",
    "dev:full": "concurrently -n web,worker -c blue,magenta \"pnpm dev\" \"pnpm worker\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@stripe/stripe-js": "^9.6.0",
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
